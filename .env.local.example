# Neon-koppeling (invullen zodra het Neon-project is aangemaakt).
# Zolang deze leeg is draait de app in LOKALE MODUS: data wordt opgeslagen
# in data/db.json en er is geen login nodig.
# Aanmaken op https://console.neon.tech → project → Connect → kopieer de
# "pooled connection" connection string (inclusief wachtwoord).
# GEHEIM — nooit met NEXT_PUBLIC_ prefixen, nooit delen of committen.
DATABASE_URL=

# Verplicht zodra DATABASE_URL is ingevuld: ondertekent de login-sessies
# (Auth.js). Genereer een willekeurige waarde, bv. met:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# GEHEIM — nooit delen of committen.
AUTH_SECRET=

# Alleen nodig voor het AI-advies bij Wedstrijdanalyses (Claude API).
# Aanmaken op https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Alleen nodig om reistijden naar uitwedstrijden automatisch op te halen (Programma).
# Aanmaken in Google Cloud Console, met de "Distance Matrix API" ingeschakeld.
# GEHEIM — nooit met NEXT_PUBLIC_ prefixen, nooit delen of committen.
GOOGLE_MAPS_API_KEY=
