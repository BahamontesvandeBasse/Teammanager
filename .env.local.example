# Supabase-koppeling (invullen zodra het Supabase-project is aangemaakt).
# Zolang deze leeg zijn draait de app in LOKALE MODUS: data wordt opgeslagen
# in data/db.json en er is geen login nodig.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Alleen nodig voor het mobiele spelersscherm (/mijn/[token]) zodra Supabase
# actief is: spelers loggen niet in, dus die routes gebruiken de service-role
# key (Settings → API → "service_role") om zonder sessie te kunnen lezen/schrijven.
# GEHEIM — nooit met NEXT_PUBLIC_ prefixen, nooit delen of committen.
SUPABASE_SERVICE_ROLE_KEY=

# Alleen nodig voor het AI-advies bij Wedstrijdanalyses (Claude API).
# Aanmaken op https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Alleen nodig om reistijden naar uitwedstrijden automatisch op te halen (Programma).
# Aanmaken in Google Cloud Console, met de "Distance Matrix API" ingeschakeld.
# GEHEIM — nooit met NEXT_PUBLIC_ prefixen, nooit delen of committen.
GOOGLE_MAPS_API_KEY=
